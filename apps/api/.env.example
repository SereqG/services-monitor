APP_NAME="Services Monitor API"
DEBUG=false

# Comma-separated browser origins allowed to call the API (e.g.
# "https://app.example.com,https://admin.example.com"). Empty = no cross-origin.
CORS_ALLOWED_ORIGINS=

# Directory for the log file. Empty = log to stdout only (recommended in containers).
LOG_DIR=

HTTP_TIMEOUT=30.0
HTTP_MAX_REDIRECTS=10
USER_AGENT="ServiceMonitorBot/1.0 (+https://services-monitor.io/bot)"

DISCOVERY_MAX_URLS=500
DISCOVERY_MAX_DEPTH=3
DISCOVERY_MAX_DURATION_SECONDS=120
DISCOVERY_MAX_REQUESTS=1000

AUDIT_MAX_DURATION_SECONDS=240
AUDIT_MAX_PAGES=50
AUDIT_DEFAULT_PAGES=15

# AI-powered audit summary. The LLM API key + provider are supplied per request
# by the user (stored in their browser), so there is NO server-side LLM key here.
# AI_SUMMARY_ENABLED is a server-wide kill switch; the model is fixed per provider.
AI_SUMMARY_ENABLED=true
AI_SUMMARY_TIMEOUT_SECONDS=45.0
AI_SUMMARY_MAX_TOKENS=8192
AI_SUMMARY_MAX_TOOL_ITERATIONS=4
AI_STORAGE_DIR=
SUMMARIES_DIR=
